# Supabase 配置
# 仅用于数据库读写。纯 OSS 方案下，文件存储走阿里云 OSS。
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# 可选：兼容旧配置，未提供 service role key 时才会回退使用
# SUPABASE_KEY=your_supabase_key

# Aliyun OSS 配置
# 用于文件存储（iOS Kit Bucket）
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET_NAME=ios-kit

# Anthropic API Key
# 用于 AI 生成功能
ANTHROPIC_API_KEY=your_anthropic_api_key

# 前端 API 基础 URL（可选）
# 默认：http://localhost:8000
# PUBLIC_API_BASE_URL=http://localhost:8000

# Stripe 配置
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_BASE=price_base_project
STRIPE_PRICE_ID_PRO=price_pro_project
PUBLIC_SITE_URL=http://localhost:3003
